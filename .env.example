JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=sonar
# SONAR_TOKEN is filled in automatically by scripts/bootstrap-sonar.sh.
SONAR_TOKEN=
DATASOURCE_USER=postgres
DATASOURCE_PASSWORD=postgres
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
TOKEN_KEY=someVeryLongRandomSecretKeyForLocalDevOnly1234567890
EMAIL_ADDRESS=
EMAIL_PASSWORD=
CLOUD_NAME=
API_KEY=
API_SECRET=
BUCKET_NAME=
STATIC_URL=
GOOGLE_CLIENT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# The AZURE keys need *some* value (dummy is fine) or core won't start.
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=dummy;AccountKey=ZHVtbXk=;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=dummy-container

MAX_FILE_SIZE=2MB
MAX_REQUEST_SIZE=2MB
DEFAULT_PROFILE_PICTURE=

# --- Frontend build args (changing them requires rebuilding the client) -----
PRODUCTION=true
ENABLE_GREENCITY=true
ENABLE_UBS=false
BACKEND_LINK=http://localhost:8080
BACKEND_USER_LINK=http://localhost:8060
BACKEND_CHAT_LINK=http://localhost:8080
BACKEND_UBS_LINK=http://localhost:8080
BACKEND_UBS_ADMIN_LINK=http://localhost:8080
SOCKET=http://localhost:8080/socket
USER_SOCKET=http://localhost:8060/socket
UBS_SOCKET=http://localhost:8080/socket
FRONTEND_LINK=http://localhost:4200
API_KEYS=
API_MAP_KEY=
AGM_CORE_MODULE_API_KEY=

